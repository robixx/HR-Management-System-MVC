@model List<Itc.Hris.Application.ModelView.MenuPermissionDto>


@{
    
    ViewBag.Title = "Page Permission";
    ViewBag.pTitle = "Role wise Page Permission";
    ViewBag.pageTitle = "HRIS";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
}
@section styles {
    <link href="@Url.Content("~/assets/libs/select2/css/select2.min.css")" rel="stylesheet" />
    <link href="@Url.Content("~/assets/libs/bootstrap-datepicker/css/bootstrap-datepicker.min.css")" rel="stylesheet" />
    <link href="@Url.Content("~/assets/libs/admin-resources/jquery.vectormap/jquery-jvectormap-1.2.2.css")" rel="stylesheet" />
    <link href="@Url.Content("~/assets/libs/datatables.net-bs4/css/dataTables.bootstrap4.min.css")" rel="stylesheet" />
    <link href="@Url.Content("~/assets/libs/datatables.net-responsive-bs4/css/responsive.bootstrap4.min.css")" rel="stylesheet" />
    <link rel="stylesheet" type="text/css" href="@Url.Content("~/assets/libs/toastr/build/toastr.min.css")">
}


<div class="row">
    <div class="col-12">
        <div class="card">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-@TempData["Status"] alert-dismissible fade show" role="alert">
                    @TempData["Message"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <div class="card-body">
                <form asp-area="Admin" asp-controller="Security" asp-action="PagePermission" method="post">
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Role Selection</label>
                            @Html.DropDownList("RoleId", ViewBag.RoleList as SelectList, "  Select Role  ", new { @class = "form-control select2" })
                        </div>
                        <div class="col-auto d-flex align-items-end">
                            <button type="submit" name="btnTrigger" value="load" class="btn btn-primary">
                                <i class="fas fa-search me-1"></i> Load Page
                            </button>
                        </div>
                    </div>
                    <!-- Permissions Section (Only show if model has data) -->
                    @if (Model != null && Model.Any())
                    {
                        <hr />
                        
                        <!-- Save Button -->
                        <div class="text-end mb-3">
                            <button type="submit" name="btnTrigger" value="save" class="btn btn-primary btn-sm">
                                <i class="fas fa-save me-2"></i> Save View Permissions
                            </button>
                        </div>

                        <!-- Menu Tree -->
                        <div class="menu-tree">
                            @foreach (var menu in Model)
                            {
                                <div class="menu-item mb-3">
                                    <!-- Main Menu -->
                                    <div class="main-menu d-flex align-items-center p-2 rounded"
                                         style="background-color: #f8f9fa; border-left: 4px solid #0d6efd;">
                                        <div class="form-check">
                                            <input class="form-check-input main-menu-check"
                                                   type="checkbox"
                                                   name="SelectedMenus"
                                                   value="@menu.MenuId"
                                                   id="menu_@menu.MenuId"
                                            @(menu.HasPermission == 1 ? "checked" : "")
                                                   data-menu-id="@menu.MenuId">
                                            <label class="form-check-label fw-bold ms-2" for="menu_@menu.MenuId">
                                                @if (!string.IsNullOrEmpty(menu.Icon))
                                                {
                                                    <i class="@menu.Icon me-2"></i>
                                                }
                                                @menu.MenuName
                                            </label>
                                        </div>
                                    </div>

                                    <!-- Sub Menus -->
                                    @if (menu.Permissions != null && menu.Permissions.Any())
                                    {
                                        <div class="sub-menu ms-4 mt-2 ps-3 border-start">
                                            @foreach (var sub in menu.Permissions)
                                            {
                                                <div class="sub-menu-item d-flex align-items-center py-1">
                                                    <div class="form-check">
                                                        <input class="form-check-input sub-menu-check"
                                                               type="checkbox"
                                                               name="SelectedMenus"
                                                               value="@sub.MenuId"
                                                               id="sub_@sub.MenuId"
                                                        @(sub.HasPermission == 1 ? "checked" : "")
                                                               data-parent-id="@menu.MenuId">
                                                        <label class="form-check-label ms-2" for="sub_@sub.MenuId">
                                                            @if (!string.IsNullOrEmpty(sub.Icon))
                                                            {
                                                                <i class="@sub.Icon me-2 text-muted"></i>
                                                            }
                                                            <span class="text-secondary">@sub.MenuName</span>
                                                        </label>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <i class="fas fa-info-circle me-2"></i>
                            Select a role and click "Load Page" to view permissions.
                        </div>
                    }
                </form>
              
            </div>
        </div>
    </div>
</div>







@section scripts {
    <!-- apexcharts -->
    <script src="@Url.Content("~/assets/libs/select2/js/select2.min.js")"></script>
    <script src="@Url.Content("~/assets/libs/spectrum-colorpicker2/spectrum.min.js")"></script>
    <script src="@Url.Content("~/assets/libs/bootstrap-datepicker/js/bootstrap-datepicker.min.js")"></script>
    <script src="@Url.Content("~/assets/libs/bootstrap-touchspin/jquery.bootstrap-touchspin.min.js")"></script>
    <script src="@Url.Content("~/assets/libs/admin-resources/jquery.vectormap/jquery-jvectormap-1.2.2.min.js")"></script>
    <script src="@Url.Content("~/assets/libs/admin-resources/jquery.vectormap/maps/jquery-jvectormap-us-merc-en.js")"></script>
    <script src="@Url.Content("~/assets/libs/datatables.net/js/jquery.dataTables.min.js")"></script>
    <script src="@Url.Content("~/assets/libs/datatables.net-bs4/js/dataTables.bootstrap4.min.js")"></script>
    <script src="@Url.Content("~/assets/libs/datatables.net-responsive/js/dataTables.responsive.min.js")"></script>
    <script src="@Url.Content("~/assets/libs/datatables.net-responsive-bs4/js/responsive.bootstrap4.min.js")"></script>
   @*  <script src="@Url.Content("~/assets/js/pages/datatables.init.js")"></script> *@
    <script src="@Url.Content("~/assets/libs/toastr/build/toastr.min.js")"></script>

    <!-- toastr init -->
    <script src="@Url.Content("~/assets/js/pages/toastr.init.js")"></script>
    <script src="@Url.Content("~/assets/libs/bootstrap-maxlength/bootstrap-maxlength.min.js")"></script>
    <script src="@Url.Content("~/assets/js/pages/form-advanced.init.js")"></script>
    <script src="@Url.Content("~/assets/js/app.js")"></script>


}
<script src="~/assets/libs/jquery/jquery.min.js"></script>


<script>
   
    document.addEventListener("DOMContentLoaded", function() {
   
        const alertElement = document.querySelector('.alert');
        
        if (alertElement) {
    
            setTimeout(function() {
            // Use Bootstrap's built-in alert 'close' method
            const alert = new bootstrap.Alert(alertElement);
            alert.close();
            }, 2000);
            }
    });
</script>